<?xml version="1.0" encoding="UTF-16"?>
<!--
  SynaSystems-Watchdog Task Scheduler Definition
  ==============================================
  Task Name : SynaSystems-Watchdog
  Trigger   : Mon–Fri at 11:00 AM (Asia/Calcutta / IST, UTC+05:30)
  Action    : python D:/ShivamGem/SynaSystems/scripts/watchdog.py
  Import    : schtasks /create /xml "schedule_watchdog.xml" /tn "SynaSystems-Watchdog"
-->
<Task version="1.4" xmlns="http://schemas.microsoft.com/windows/2004/02/mit/task">

  <!-- ═══════════════════════════ REGISTRATION ═══════════════════════════ -->
  <RegistrationInfo>
    <Date>2026-06-20T11:00:00</Date>
    <Author>SynaSystems-Automation</Author>
    <Description>Daily weekday watchdog for Syna Systems agency-brain health checks, lead pipeline monitoring, and CI/CD status reporting.</Description>
    <URI>\SynaSystems-Watchdog</URI>
  </RegistrationInfo>

  <!-- ═════════════════════════════ TRIGGERS ════════════════════════════ -->
  <Triggers>
    <CalendarTrigger>
      <StartBoundary>2026-06-22T11:00:00</StartBoundary>
      <!-- No EndBoundary — runs indefinitely -->
      <Enabled>true</Enabled>
      <ScheduleByWeek>
        <WeeksInterval>1</WeeksInterval>
        <DaysOfWeek>
          <Monday />
          <Tuesday />
          <Wednesday />
          <Thursday />
          <Friday />
        </DaysOfWeek>
      </ScheduleByWeek>
    </CalendarTrigger>
  </Triggers>

  <!-- Principals block removed to default to the current user context -->

  <!-- ═══════════════════════════ SETTINGS ════════════════════════════ -->
  <Settings>
    <MultipleInstancesPolicy>IgnoreNew</MultipleInstancesPolicy>
    <!-- Run even when the machine is on battery -->
    <DisallowStartIfOnBatteries>false</DisallowStartIfOnBatteries>
    <StopIfGoingOnBatteries>false</StopIfGoingOnBatteries>
    <!-- Wake the PC if asleep at trigger time -->
    <WakeToRun>true</WakeToRun>
    <ExecutionTimeLimit>PT1H</ExecutionTimeLimit>
    <RestartOnFailure>
      <Interval>PT5M</Interval>
      <Count>3</Count>
    </RestartOnFailure>
    <Enabled>true</Enabled>
    <Hidden>false</Hidden>
    <!-- Run whether user is logged on or not -->
    <RunOnlyIfNetworkAvailable>false</RunOnlyIfNetworkAvailable>
    <IdleSettings>
      <StopOnIdleEnd>false</StopOnIdleEnd>
      <RestartOnIdle>false</RestartOnIdle>
    </IdleSettings>
    <!-- Run task ASAP if a scheduled start is missed -->
    <StartWhenAvailable>true</StartWhenAvailable>
    <RunOnlyIfIdle>false</RunOnlyIfIdle>
    <UseUnifiedSchedulingEngine>true</UseUnifiedSchedulingEngine>
  </Settings>

  <!-- ═══════════════════════════ ACTIONS ═════════════════════════════ -->
  <Actions>
    <Exec>
      <!-- Use the full path to the Python executable for reliability -->
      <Command>python</Command>
      <Arguments>D:\ShivamGem\SynaSystems\scripts\watchdog.py</Arguments>
      <!-- Working directory so relative paths inside watchdog.py resolve correctly -->
      <WorkingDirectory>D:\ShivamGem\SynaSystems</WorkingDirectory>
    </Exec>
  </Actions>

</Task>
